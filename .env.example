# Subway Therapy Environment Variables
# Copy this file to .env.local and fill in the values

# Admin API key for moderation dashboard authentication
# Required in production
ADMIN_API_KEY=your-secure-admin-key-here

# Secret used to sign admin session cookies
ADMIN_SESSION_SECRET=your-random-session-signing-secret

# Vercel Blob Storage (for production image storage)
# Get these from your Vercel project settings
BLOB_READ_WRITE_TOKEN=

# Convex Database (for production note metadata storage)
# Get this from your Convex dashboard at https://dashboard.convex.dev
CONVEX_DEPLOY_KEY=
NEXT_PUBLIC_CONVEX_URL=

# Shared secret used to authorize server-to-server calls into privileged
# Convex functions (note creation, moderation, flagging, cooldowns). Set
# the same value as an environment variable on the Convex deployment
# (`npx convex env set CONVEX_SERVER_SECRET <value>`) so the functions can
# validate it. Generate a long random string, e.g. `openssl rand -hex 32`.
CONVEX_SERVER_SECRET=

# Vercel AI Gateway (for automatic content moderation)
# Get this from your Vercel dashboard: https://vercel.com/account/ai-gateway
# Uses meta/llama-4-scout for image content moderation
# Cost: ~$0.11 per 1,000 notes moderated
AI_GATEWAY_API_KEY=

# Secret seed for server-side abuse and rate-limiting hashes
RATE_LIMIT_SECRET=your-random-rate-limit-secret

# Optional: Site URL for SEO metadata
NEXT_PUBLIC_SITE_URL=https://subwaytherapy.net

# Optional: Analytics and monitoring
# NEXT_PUBLIC_ANALYTICS_ID=
